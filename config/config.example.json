{
  "server": {
    "bind": "0.0.0.0:8080",
    "request_timeout_seconds": 300
  },
  "targets": [
    {
      "name": "my-azure-target",
      "endpoint_type": "azure_openai",
      "endpoint": "https://<resource>.openai.azure.com/",
      "resource_path_prefix": "/openai",
      "api_key": "<your-api-key>",
      "allow_bearer_passthrough": false,
      "allowed_models": []
    }
  ],
  "data_store": {
    "db_path": "/var/lib/llms-proxy/llms-proxy.db"
  },
  "data_files": {
    "clients_file": "",
    "model_costs_file": "",
    "usage_events_file": "",
    "admin_users_file": "",
    "admin_audit_file": ""
  },
  "admin_session": {
    "cookie_name": "llms_proxy_admin_session",
    "secret": "change-me-on-first-login",
    "ttl_seconds": 86400,
    "sliding_expiration": true,
    "secure_cookie": false
  },
  "logging": {
    "level": "info",
    "access_log": "/var/log/llms-proxy/access.log",
    "error_log": "/var/log/llms-proxy/error.log"
  }
}
