{
  "server": {
    "bind": "0.0.0.0:8000",
    "request_timeout_seconds": 300
  },
  "azure_targets": [
    {
      "name": "East US 2",
      "endpoint_type": "azure_openai",
      "endpoint": "https://yc-east2-us-gpt.openai.azure.com/",
      "resource_path_prefix": "/openai",
      "azure_api_key": "REDACTED_KEY_3",
      "allow_bearer_passthrough": false,
      "allowed_models": [
        "gpt-image-1.5",
        "text-embedding-3-large",
        "gpt-5.2",
        "gpt-5.2-chat",
        "gpt-5.3-codex",
        "gpt-5.4-mini",
        "gpt-5.4-nano"
      ]
    },
    {
      "name": "North Central US",
      "endpoint_type": "azure_openai",
      "endpoint": "https://yc-north-us-gpt.openai.azure.com/",
      "resource_path_prefix": "/openai",
      "azure_api_key": "REDACTED_KEY_4",
      "allow_bearer_passthrough": false,
      "allowed_models": [
        "tts",
        "tts-hd",
        "whisper"
      ]
    },
    {
      "name": "Claude",
      "endpoint_type": "claude",
      "endpoint": "https://aigateway.edgecloudapp.com/v2/gws/1il16qpv/anthropic/",
      "resource_path_prefix": "",
      "azure_api_key": "REDACTED_KEY_1",
      "allow_bearer_passthrough": false,
      "allowed_models": [
        "claude-sonnet-4-6",
        "claude-opus-4-6"
      ]
    }
  ],
  "data_files": {
    "clients_file": "/etc/llms-proxy/clients.json",
    "model_costs_file": "/etc/llms-proxy/model_costs.json",
    "usage_events_file": "/etc/llms-proxy/usage_events.jsonl",
    "admin_users_file": "/etc/llms-proxy/admin_users.json",
    "admin_audit_file": "/etc/llms-proxy/admin_audit.jsonl"
  },
  "admin_session": {
    "cookie_name": "llms_proxy_admin_session",
    "secret": "dev-session-secret-change-me",
    "ttl_seconds": 86400,
    "sliding_expiration": true,
    "secure_cookie": false
  },
  "logging": {
    "level": "info",
    "access_log": "/var/log/llms-proxy/access.log",
    "error_log": "/var/log/llms-proxy/error.log"
  }
}
