# Copy this file to .env and adjust to match your environment.

# Host/container port (HOST:CONTAINER)
PROXY_PORT=8080
# docker-compose sets SERVER_BIND to 0.0.0.0:${PROXY_PORT}

# Log verbosity propagated to the container (info, debug, warn, error)
LOG_LEVEL=info

# Directory containing config.json on the host
CONFIG_DIR=/DATA/Azure-Proxy/config

# Directory where container logs will be written on the host
LOG_PATH=/DATA/Azure-Proxy/logs
