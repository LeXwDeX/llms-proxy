# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Project binaries
bin/

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Runtime logs
logs/
!logs/.gitkeep

# Runtime data (config/ only tracks .gitkeep; all data files are generated at runtime)
config/*
!config/.gitkeep

# Vibe-coding / AI assistant artifacts
AGENTS.md
CLAUDE.md
COPILOT.md
GEMINI.md
CURSOR.md
WINDSURF.md
.github/copilot-instructions.md
.aider*
.claude/
.copilot/
.cursor/
.gemini/
.continue/
.roo/
.codex/
.codex_plan/

# One-time migration scripts (not part of the project)
migrate-to-bbolt.sh
